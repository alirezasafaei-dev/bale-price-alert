# Application Configuration
ENVIRONMENT=production
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/novax_price_alert
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://novax.alirezasafeidev.ir/api/v1/webhook
TELEGRAM_RELAY_URL=https://your-relay-url.example.com
TELEGRAM_RELAY_SECRET=your_relay_secret_here

# API Security Tokens (Generate strong random strings)
ADMIN_ACCESS_TOKEN=your_strong_random_admin_token_here_64_chars_minimum
INGEST_API_TOKEN=your_strong_random_ingest_token_here_64_chars_minimum

# AI Configuration (Optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# VPS Deployment Configuration
VPS_IP=193.93.169.58
VPS_USER=ubuntu
VPS_SSH_KEY_PATH=~/.ssh/id_rsa
VPS_PORT=22
APP_DIR=/home/deploy/novax-price-alert
DOMAIN=novax.alirezasafeidev.ir

# CORS Configuration
ALLOWED_ORIGINS=https://novax.alirezasafeidev.ir,https://*.alirezasafeidev.ir,https://t.me,https://web.telegram.org

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Security Settings
SECRET_KEY=your_django_like_secret_key_here_minimum_32_chars
SESSION_TIMEOUT=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=8001